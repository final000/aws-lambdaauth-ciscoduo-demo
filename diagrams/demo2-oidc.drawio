        <mxCell id="title" parent="1" style="text;html=1;fontSize=18;fontStyle=1;align=center;" value="Demo 2: OIDC Universal Prompt (Duo Web SDK)" vertex="1">
          <mxGeometry height="30" width="550" x="250" y="20" as="geometry" />
        </mxCell>
        <mxCell id="browser" parent="1" style="shape=actor;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" value="Browser&#xa;(Frontend)" vertex="1">
