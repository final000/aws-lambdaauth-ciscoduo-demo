        <mxCell id="apigw" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" value="API Gateway&#xa;(REST API)" vertex="1">
          <mxGeometry height="70" width="140" x="210" y="380" as="geometry" />
        </mxCell>
        <mxCell id="login" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" value="Login Lambda&#xa;(mock auth +&#xa;Duo redirect)" vertex="1">
