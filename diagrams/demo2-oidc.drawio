        <mxCell id="hello" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" value="Protected&#xa;Lambda" vertex="1">
          <mxGeometry height="70" width="140" x="720" y="400" as="geometry" />
        </mxCell>
        <mxCell id="e1" edge="1" parent="1" source="browser" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=10;" target="login" value="1. POST /login&#xa;(username + password)">
